      "source": [
        "class Human:\n",
        "  def __init__(self, age):\n",
        "    self.age = age\n",
        "  def check_adult(self):\n",
        "    print(f\"年齢：{self.age}\")\n",
        "    if self.age >= 20:\n",
        "      print(f\"大人である\")\n",
        "    else:\n",
        "      print(f\"大人でない\")\n",
        "hms = [Human(29), Human(10), Human(40), Human(19), Human(20)]\n",
        "for hm in hms:\n",
        "  hm.check_adult()"
      ]
    }
  ]
}