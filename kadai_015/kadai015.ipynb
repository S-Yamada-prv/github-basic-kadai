        "class Human:\n",
        "  def __init__(self, name, age):\n",
        "    self.name = name\n",
        "    self.age = age\n",
        "  def printinfo(self):\n",
        "    print(f\"名前：{self.name}\")\n",
        "    print(f\"年齢：{str(self.age)}\")\n",
        "hm = Human(\"名前太郎\", 29)\n",
        "hm.printinfo()"
      ]
